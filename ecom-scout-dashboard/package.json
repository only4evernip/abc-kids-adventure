{
  "name": "ecom-scout-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:sync": "tsc -p tsconfig.sync.json",
    "sync:feishu": "node scripts/syncFeishu.mjs",
    "scout:generate": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/scoutGenerate.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3",
    "papaparse": "^5.5.2",
    "zod": "^3.24.2",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.11.2"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/papaparse": "^5.3.16",
    "vitest": "^3.2.4"
  }
}
