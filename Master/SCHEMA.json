{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Master A-Share Trading Agent Schema",
  "description": "Decision-layer output schema for Master. Agent should output only valid JSON matching this schema. Markdown reports are rendered downstream.",
  "type": "object",
  "properties": {
    "market_overview": {
      "type": "object",
      "properties": {
        "environment_reasoning": { "type": "string" },
        "environment_label": {
          "type": "string",
          "enum": ["进攻", "试错", "混沌", "防守"]
        },
        "emotion_cycle_reasoning": { "type": "string" },
        "emotion_cycle": {
          "type": "string",
          "enum": ["冰点", "修复", "主升", "高潮", "强分歧", "退潮", "混沌"]
        },
        "market_score_reasoning": { "type": "string" },
        "market_score": { "type": "number" },
        "turnover_total": { "type": "number" },
        "up_count": { "type": "number" },
        "down_count": { "type": "number" },
        "limit_up_count": { "type": "number" },
        "limit_down_count": { "type": "number" },
        "blowup_rate": { "type": "number" },
        "highest_board": { "type": "number" },
        "northbound_net_inflow": { "type": "number" },
        "main_theme": { "type": "string" },
        "secondary_theme": { "type": "string" },
        "retreat_theme": { "type": "string" },
        "recommended_style_reasoning": { "type": "string" },
        "recommended_style": { "type": "string" },
        "forbidden_style_reasoning": { "type": "string" },
        "forbidden_style": { "type": "string" },
        "allow_level_2_reasoning": { "type": "string" },
        "allow_level_2": { "type": "boolean" },
        "risk_flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "environment_reasoning",
        "environment_label",
        "emotion_cycle_reasoning",
        "emotion_cycle",
        "market_score_reasoning",
        "market_score",
        "turnover_total",
        "limit_up_count",
        "limit_down_count",
        "recommended_style",
        "forbidden_style",
        "allow_level_2",
        "allow_level_2_reasoning"
      ]
    },
    "sector_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sector_name": { "type": "string" },
          "sector_reasoning": { "type": "string" },
          "sector_stage_reasoning": { "type": "string" },
          "sector_stage": {
            "type": "string",
            "enum": ["启动", "发酵", "主升", "强分歧", "高位震荡", "退潮", "退潮反抽", "一日游"]
          },
          "sector_score_reasoning": { "type": "string" },
          "sector_score": { "type": "number" },
          "leader_stock": { "type": "string" },
          "core_midcap_stock": { "type": "string" },
          "follow_strength": { "type": "string" },
          "health_reasoning": { "type": "string" },
          "health_status": {
            "type": "string",
            "enum": ["健康", "一般", "分歧", "危险"]
          },
          "is_main_theme_reasoning": { "type": "string" },
          "is_main_theme": { "type": "boolean" },
          "allow_level_3_reasoning": { "type": "string" },
          "allow_level_3": { "type": "boolean" },
          "anti_fraud_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action_reasoning": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["回避", "观察", "小仓试错", "重点跟踪", "可择机参与", "减仓", "退出"]
          }
        },
        "required": [
          "sector_name",
          "sector_reasoning",
          "sector_stage_reasoning",
          "sector_stage",
          "sector_score_reasoning",
          "sector_score",
          "health_reasoning",
          "health_status",
          "is_main_theme_reasoning",
          "is_main_theme",
          "allow_level_3_reasoning",
          "allow_level_3",
          "action_reasoning",
          "action"
        ]
      }
    },
    "stock_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "stock_role_reasoning": { "type": "string" },
          "stock_role": {
            "type": "string",
            "enum": ["总龙头", "板块龙头", "情绪龙头", "趋势中军", "核心补涨", "跟风", "杂毛", "反抽股"]
          },
          "matched_market_reasoning": { "type": "string" },
          "matched_market": { "type": "boolean" },
          "matched_theme_reasoning": { "type": "string" },
          "matched_theme": { "type": "boolean" },
          "signal_reasoning": { "type": "string" },
          "signal_type": {
            "type": "string",
            "enum": ["分歧低吸", "回踩确认", "突破确认", "打板确认", "观察", "高位风险", "破位卖点", "退出信号"]
          },
          "signal_score_reasoning": { "type": "string" },
          "signal_score": { "type": "number" },
          "risk_warning": { "type": "string" },
          "invalid_condition": { "type": "string" },
          "anti_fraud_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action_reasoning": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["回避", "观察", "小仓试错", "重点跟踪", "可择机建仓", "可趋势持有", "减仓", "退出"]
          }
        },
        "required": [
          "symbol",
          "name",
          "stock_role_reasoning",
          "stock_role",
          "matched_market_reasoning",
          "matched_market",
          "matched_theme_reasoning",
          "matched_theme",
          "signal_reasoning",
          "signal_type",
          "signal_score_reasoning",
          "signal_score",
          "action_reasoning",
          "action"
        ]
      }
    },
    "allocation_plan": {
      "type": "object",
      "properties": {
        "plan_reasoning": { "type": "string" },
        "total_equity_target": { "type": "number" },
        "true_defensive_weight": { "type": "number" },
        "equity_defensive_weight": { "type": "number" },
        "core_weight": { "type": "number" },
        "satellite_weight": { "type": "number" },
        "a_share_weight": { "type": "number" },
        "h_share_weight": { "type": "number" },
        "rebalance_action": { "type": "string" },
        "rebalance_reasoning": { "type": "string" },
        "fund_pool_focus": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_controls": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "required": ["market_overview", "sector_analysis", "stock_analysis"]
}
